{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
	"id": "fitdeck-speed",
	"items": [
		{
			"key": "title",
			"type": "text",
			"rect": [0, 0, 200, 24],
			"font": { "size": 12 },
			"alignment": "center",
			"color": "#AAAAAA"
		},
		{
			"key": "value",
			"type": "text",
			"rect": [0, 24, 200, 46],
			"font": { "size": 28, "weight": 700 },
			"alignment": "center",
			"color": "#FFFFFF"
		},
		{
			"key": "indicator",
			"type": "bar",
			"rect": [10, 76, 180, 14],
			"value": 0,
			"bar_bg_c": "0:#333333",
			"bar_fill_c": "0:#00CC66"
		}
	]
}
