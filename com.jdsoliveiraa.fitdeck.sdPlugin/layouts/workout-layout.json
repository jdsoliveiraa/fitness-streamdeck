{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
	"id": "fitdeck-workout",
	"items": [
		{
			"key": "title",
			"type": "text",
			"rect": [0, 0, 200, 22],
			"font": { "size": 11 },
			"alignment": "center",
			"color": "#AAAAAA"
		},
		{
			"key": "value",
			"type": "text",
			"rect": [0, 22, 200, 32],
			"font": { "size": 20, "weight": 700 },
			"alignment": "center",
			"color": "#FFFFFF"
		},
		{
			"key": "subtitle",
			"type": "text",
			"rect": [0, 54, 200, 18],
			"font": { "size": 10 },
			"alignment": "center",
			"color": "#888888"
		},
		{
			"key": "indicator",
			"type": "bar",
			"rect": [10, 78, 180, 14],
			"value": 0,
			"bar_bg_c": "0:#333333",
			"bar_fill_c": "0:#FF9900"
		}
	]
}
